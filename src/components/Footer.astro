---
const BASE = '/my-site';
const currentYear = new Date().getFullYear();

const footerLinks = [
  { name: 'Home', href: BASE + '/' },
  { name: 'About', href: BASE + '/about' },
  { name: 'Projects', href: BASE + '/projects' },
  { name: 'Blog', href: BASE + '/blog' },
  { name: 'Contact', href: BASE + '/contact' },
];

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/></svg>`,
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    name: 'Twitter',
    href: 'https://twitter.com',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<footer class="bg-gray-50 border-t border-gray-200 mt-auto">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/my-site/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center text-white font-bold text-sm">
            AI
          </div>
          <span class="font-bold text-lg text-gray-900">AI Portfolio</span>
        </a>
        <p class="text-sm text-gray-600 leading-relaxed">
          Showcasing AI projects, experiments, and technical insights.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-semibold text-gray-900 mb-4">Navigation</h3>
        <ul class="space-y-2">
          {footerLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-semibold text-gray-900 mb-4">Connect</h3>
        <div class="flex gap-3">
          {socialLinks.map(social => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 bg-white border border-gray-200 rounded-lg flex items-center justify-center text-gray-600 hover:text-indigo-600 hover:border-indigo-300 hover:shadow-md transition-all duration-200"
              aria-label={social.name}
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="border-t border-gray-200 mt-8 pt-8 text-center">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} AI Portfolio. All rights reserved.
      </p>
    </div>
  </div>
</footer>
