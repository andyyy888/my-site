---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getGitHubRepos, getLanguageColor } from '../../lib/github';

const GITHUB_USERNAME = 'andyyy888'; // TODO: Replace with your GitHub username

let allRepos: Awaited<ReturnType<typeof getGitHubRepos>> = [];

try {
  allRepos = await getGitHubRepos(GITHUB_USERNAME);
} catch (error) {
  console.error('Failed to fetch repositories:', error);
}

const repos = allRepos.filter(r => !r.fork && !r.archived);
const totalStars = repos.reduce((sum, r) => sum + r.stargazers_count, 0);
const totalForks = repos.reduce((sum, r) => sum + r.forks_count, 0);

const allLanguages = [...new Set(repos.map(r => r.language).filter(Boolean))] as string[];
const allTopics = [...new Set(repos.flatMap(r => r.topics))];
---

<Layout title="Projects" description="Explore all AI and machine learning projects including code, demos, and technical writeups.">
  <Navbar />

  <main class="flex-1">
    <!-- Header -->
    <section class="bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-20">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 animate-fade-in" style="opacity: 0;">
          All Projects
        </h1>
        <p class="text-xl text-gray-600 mb-8 animate-fade-in stagger-1" style="opacity: 0;">
          A collection of AI experiments, open-source tools, and technical projects.
        </p>

        <!-- Quick Stats -->
        <div class="flex flex-wrap gap-6 animate-fade-in stagger-2" style="opacity: 0;">
          <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-sm border border-gray-100">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            <span class="font-bold text-gray-900">{repos.length}</span>
            <span class="text-gray-500">Projects</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-sm border border-gray-100">
            <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="font-bold text-gray-900">{totalStars}</span>
            <span class="text-gray-500">Stars</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-sm border border-gray-100">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7 10H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H7zm0 0h10v2H7v-2zm12 4H7v-2h12v2z"/>
            </svg>
            <span class="font-bold text-gray-900">{totalForks}</span>
            <span class="text-gray-500">Forks</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-sm border border-gray-100">
            <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            <span class="font-bold text-gray-900">{allTopics.length}</span>
            <span class="text-gray-500">Topics</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Filters -->
    <section class="bg-white border-b border-gray-100 sticky top-16 z-40 backdrop-blur-md bg-white/80">
      <div class="max-w-6xl mx-auto px-6 py-4">
        <div class="flex flex-col md:flex-row gap-4">
          <!-- Search -->
          <div class="relative flex-1">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input
              type="text"
              id="search-input"
              placeholder="Search projects..."
              class="w-full pl-12 pr-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
            />
          </div>

          <!-- Language Filter -->
          <div class="flex items-center gap-2">
            <select
              id="language-filter"
              class="px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all cursor-pointer"
            >
              <option value="">All Languages</option>
              {allLanguages.map(lang => (
                <option value={lang}>{lang}</option>
              ))}
            </select>
          </div>
        </div>

        <!-- Topic Tags -->
        {allTopics.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4" id="topic-filters">
            <button
              data-topic=""
              class="topic-btn active px-3 py-1.5 text-sm font-medium rounded-lg bg-indigo-600 text-white transition-all"
            >
              All
            </button>
            {allTopics.slice(0, 12).map(topic => (
              <button
                data-topic={topic}
                class="topic-btn px-3 py-1.5 text-sm font-medium rounded-lg bg-gray-100 text-gray-600 hover:bg-indigo-100 hover:text-indigo-700 transition-all"
              >
                {topic}
              </button>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Projects Grid -->
    <section class="bg-gray-50 py-12">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
          {repos.map((repo, index) => (
            <a
              href={`/projects/${repo.name}`}
              data-name={repo.name.toLowerCase()}
              data-language={repo.language?.toLowerCase() || ''}
              data-topics={repo.topics.join(',')}
              data-description={(repo.description || '').toLowerCase()}
              class={`project-card group block p-6 bg-white border border-gray-200 rounded-2xl hover:border-indigo-300 hover:shadow-xl transition-all duration-300 animate-fade-in`}
              style={`opacity: 0; animation-delay: ${Math.min(index * 50, 500)}ms;`}
            >
              <!-- Header -->
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center text-white flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
                <div class="flex items-center gap-3 text-sm">
                  <span class="flex items-center gap-1 text-gray-500">
                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    {repo.stargazers_count}
                  </span>
                  <span class="flex items-center gap-1 text-gray-500">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M7 10H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H7zm0 0h10v2H7v-2zm12 4H7v-2h12v2z"/>
                    </svg>
                    {repo.forks_count}
                  </span>
                </div>
              </div>

              <!-- Title & Description -->
              <h3 class="font-bold text-gray-900 text-lg mb-2 group-hover:text-indigo-600 transition-colors line-clamp-1">
                {repo.name}
              </h3>
              <p class="text-sm text-gray-600 mb-4 line-clamp-2">
                {repo.description || 'No description provided.'}
              </p>

              <!-- Meta -->
              <div class="flex items-center justify-between">
                {repo.language && (
                  <div class="flex items-center gap-2">
                    <span
                      class="w-3 h-3 rounded-full"
                      style={`background-color: ${getLanguageColor(repo.language)}`}
                    ></span>
                    <span class="text-sm text-gray-500">{repo.language}</span>
                  </div>
                )}

                {repo.license && (
                  <span class="text-xs text-gray-400">
                    {repo.license.spdx_id}
                  </span>
                )}
              </div>

              <!-- Topics -->
              {repo.topics.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {repo.topics.slice(0, 4).map(topic => (
                    <span class="px-2 py-1 bg-indigo-50 text-indigo-700 text-xs rounded-md">
                      {topic}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-16">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">No projects found</h3>
          <p class="text-gray-500">Try adjusting your search or filters.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const languageFilter = document.getElementById('language-filter') as HTMLSelectElement;
    const topicBtns = document.querySelectorAll('.topic-btn');
    const projectCards = document.querySelectorAll('.project-card');
    const emptyState = document.getElementById('empty-state');
    const projectsGrid = document.getElementById('projects-grid');

    let activeTopic = '';
    let activeLanguage = '';
    let searchQuery = '';

    function filterProjects() {
      let visibleCount = 0;

      projectCards.forEach(card => {
        const cardEl = card as HTMLElement;
        const name = cardEl.dataset.name || '';
        const language = cardEl.dataset.language || '';
        const topics = cardEl.dataset.topics || '';
        const description = cardEl.dataset.description || '';

        const matchesSearch = !searchQuery ||
          name.includes(searchQuery) ||
          description.includes(searchQuery) ||
          topics.includes(searchQuery);

        const matchesLanguage = !activeLanguage || language === activeLanguage;
        const matchesTopic = !activeTopic || topics.includes(activeTopic);

        if (matchesSearch && matchesLanguage && matchesTopic) {
          cardEl.style.display = 'block';
          cardEl.style.opacity = '1';
          visibleCount++;
        } else {
          cardEl.style.display = 'none';
        }
      });

      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }
    }

    searchInput?.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
      filterProjects();
    });

    languageFilter?.addEventListener('change', (e) => {
      activeLanguage = (e.target as HTMLSelectElement).value.toLowerCase();
      filterProjects();
    });

    topicBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        topicBtns.forEach(b => {
          b.classList.remove('bg-indigo-600', 'text-white', 'active');
          b.classList.add('bg-gray-100', 'text-gray-600');
        });
        btn.classList.remove('bg-gray-100', 'text-gray-600');
        btn.classList.add('bg-indigo-600', 'text-white', 'active');
        activeTopic = (btn as HTMLElement).dataset.topic || '';
        filterProjects();
      });
    });
  </script>
</Layout>
