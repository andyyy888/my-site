---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getGitHubRepos, getGitHubReadme, getLanguageColor, formatDate, type GitHubRepo } from '../../lib/github';
import { marked } from 'marked';

export async function getStaticPaths() {
  const GITHUB_USERNAME = 'andyyy888';

  let repos: GitHubRepo[] = [];
  try {
    repos = await getGitHubRepos(GITHUB_USERNAME);
  } catch (error) {
    console.error('Failed to fetch repos:', error);
    return [];
  }

  return repos
    .filter(r => !r.fork)
    .map(repo => ({
      params: { name: repo.name },
      props: { repo },
    }));
}

interface Props {
  repo: GitHubRepo;
}

const { repo } = Astro.props;
const GITHUB_USERNAME = 'andyyy888';

const readme = await getGitHubReadme(GITHUB_USERNAME, repo.name);
const readmeHtml = readme ? marked(readme) : null;
const primaryLanguage = repo.language;
---

<Layout title={repo.name} description={repo.description || `${repo.name} - AI Project`}>
  <Navbar />

  <main class="flex-1">
    <!-- Header -->
    <section class="bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-16">
      <div class="max-w-6xl mx-auto px-6">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6 animate-fade-in" style="opacity: 0;">
          <a href="/projects" class="hover:text-indigo-600 transition-colors">Projects</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-gray-900 font-medium">{repo.name}</span>
        </nav>

        <div class="flex flex-col md:flex-row gap-8 items-start">
          <!-- Icon -->
          <div class="animate-scale-in" style="opacity: 0;">
            <div class="w-24 h-24 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center text-white shadow-xl">
              <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
              </svg>
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 animate-fade-in stagger-1" style="opacity: 0;">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
              {repo.name}
            </h1>

            {repo.description && (
              <p class="text-xl text-gray-600 mb-6">
                {repo.description}
              </p>
            )}

            <!-- Stats -->
            <div class="flex flex-wrap items-center gap-6 mb-6">
              {primaryLanguage && (
                <div class="flex items-center gap-2">
                  <span
                    class="w-4 h-4 rounded-full"
                    style={`background-color: ${getLanguageColor(primaryLanguage)}`}
                  ></span>
                  <span class="text-gray-700 font-medium">{primaryLanguage}</span>
                </div>
              )}
              <div class="flex items-center gap-2 text-gray-600">
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <span>{repo.stargazers_count} stars</span>
              </div>
              <div class="flex items-center gap-2 text-gray-600">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M7 10H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H7zm0 0h10v2H7v-2zm12 4H7v-2h12v2z"/>
                </svg>
                <span>{repo.forks_count} forks</span>
              </div>
              <div class="flex items-center gap-2 text-gray-500 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span>Updated {formatDate(repo.pushed_at)}</span>
              </div>
            </div>

            <!-- Topics -->
            {repo.topics.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-8">
                {repo.topics.map(topic => (
                  <span class="px-3 py-1.5 bg-indigo-100 text-indigo-700 text-sm font-medium rounded-lg">
                    {topic}
                  </span>
                ))}
              </div>
            )}

            <!-- Actions -->
            <div class="flex flex-wrap gap-4">
              <a
                href={repo.html_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all hover:-translate-y-0.5"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
                </svg>
                View on GitHub
              </a>
              {repo.homepage && (
                <a
                  href={repo.homepage}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-6 py-3 bg-white text-gray-700 font-semibold rounded-xl border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all hover:-translate-y-0.5"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  Live Demo
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- README Content -->
    <section class="bg-white py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-3 gap-12">
          <!-- README -->
          <div class="lg:col-span-2">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Documentation</h2>

            {readmeHtml ? (
              <div class="prose prose-lg max-w-none
                prose-headings:text-gray-900
                prose-p:text-gray-600
                prose-a:text-indigo-600 hover:prose-a:text-indigo-700
                prose-strong:text-gray-900
                prose-code:text-indigo-700 prose-code:bg-indigo-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono prose-code:text-sm
                prose-pre:bg-gray-900 prose-pre:text-gray-100 prose-pre:rounded-xl
                prose-ul:text-gray-600 prose-ol:text-gray-600
                prose-li:marker:text-gray-400
                prose-blockquote:border-indigo-400 prose-blockquote:text-gray-600
                prose-img:rounded-2xl prose-img:shadow-lg
                prose-hr:border-gray-200
              ">
                <Fragment set:html={readmeHtml} />
              </div>
            ) : (
              <div class="p-8 bg-gray-50 rounded-2xl text-center">
                <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                </div>
                <p class="text-gray-500">No README found for this project.</p>
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 mt-4 text-indigo-600 hover:text-indigo-700 font-medium"
                >
                  View on GitHub
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </div>
            )}
          </div>

          <!-- Sidebar -->
          <div class="space-y-6">
            <!-- Project Info Card -->
            <div class="bg-gray-50 rounded-2xl p-6">
              <h3 class="font-bold text-gray-900 mb-4">Project Info</h3>
              <dl class="space-y-3">
                <div class="flex justify-between">
                  <dt class="text-gray-500">Created</dt>
                  <dd class="text-gray-900 font-medium">{formatDate(repo.created_at)}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-gray-500">Last Updated</dt>
                  <dd class="text-gray-900 font-medium">{formatDate(repo.updated_at)}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-gray-500">License</dt>
                  <dd class="text-gray-900 font-medium">{repo.license?.spdx_id || 'None'}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-gray-500">Visibility</dt>
                  <dd class="text-gray-900 font-medium capitalize">{repo.visibility}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-gray-500">Default Branch</dt>
                  <dd class="text-gray-900 font-medium">{repo.default_branch}</dd>
                </div>
              </dl>
            </div>

            <!-- Quick Actions -->
            <div class="bg-gray-50 rounded-2xl p-6">
              <h3 class="font-bold text-gray-900 mb-4">Quick Actions</h3>
              <div class="space-y-3">
                <a
                  href={`${repo.html_url}/archive/refs/heads/${repo.default_branch}.zip`}
                  class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all"
                >
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                  </svg>
                  <span class="text-gray-700 font-medium">Download ZIP</span>
                </a>
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all"
                >
                  <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
                  </svg>
                  <span class="text-gray-700 font-medium">View Source</span>
                </a>
                <a
                  href={`${repo.html_url}/issues`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all"
                >
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                  </svg>
                  <span class="text-gray-700 font-medium">Report Issue</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
