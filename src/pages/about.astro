---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getGitHubUser } from '../lib/github';

const GITHUB_USERNAME = 'andyyy888'; // TODO: Replace with your GitHub username

let user = null;
try {
  user = await getGitHubUser(GITHUB_USERNAME);
} catch (error) {
  console.error('Failed to fetch GitHub user:', error);
}

const experiences = [
  {
    title: 'AI Research Engineer',
    company: 'Tech Company',
    period: '2022 - Present',
    description: 'Leading development of production ML systems including NLP pipelines and computer vision applications.',
  },
  {
    title: 'Machine Learning Engineer',
    company: 'Startup Inc.',
    period: '2020 - 2022',
    description: 'Built end-to-end ML workflows from data processing to model deployment on cloud infrastructure.',
  },
];

const education = [
  {
    degree: 'M.S. in Computer Science',
    school: 'University Name',
    year: '2020',
    focus: 'Artificial Intelligence & Machine Learning',
  },
  {
    degree: 'B.S. in Computer Science',
    school: 'University Name',
    year: '2018',
    focus: 'Software Engineering',
  },
];
---

<Layout title="About" description="Learn more about my background, experience, and expertise in AI and machine learning.">
  <Navbar />

  <main class="flex-1">
    <!-- Header -->
    <section class="bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 animate-fade-in" style="opacity: 0;">
            About Me
          </h1>
          <p class="text-xl text-gray-600 animate-fade-in stagger-1" style="opacity: 0;">
            Passionate about building intelligent systems that make a difference.
          </p>
        </div>
      </div>
    </section>

    <!-- Bio Section -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
          <!-- Avatar & Social -->
          <div class="lg:w-1/3 animate-scale-in" style="opacity: 0;">
            <div class="sticky top-24">
              {user?.avatar_url ? (
                <img
                  src={user.avatar_url}
                  alt={user.name || user.login}
                  class="w-full max-w-xs rounded-2xl shadow-xl ring-4 ring-indigo-100 mb-6"
                />
              ) : (
                <div class="w-full max-w-xs aspect-square bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center text-white text-6xl font-bold shadow-xl ring-4 ring-indigo-100 mb-6">
                  AI
                </div>
              )}

              <!-- Social Links -->
              <div class="space-y-3">
                {user?.html_url && (
                  <a
                    href={user.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl hover:bg-indigo-50 transition-colors"
                  >
                    <svg class="w-5 h-5 text-gray-700" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
                    </svg>
                    <span class="font-medium text-gray-700">@{user.login}</span>
                  </a>
                )}
                {user?.location && (
                  <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="text-gray-700">{user.location}</span>
                  </div>
                )}
                {user?.blog && (
                  <a
                    href={user.blog.startsWith('http') ? user.blog : `https://${user.blog}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl hover:bg-indigo-50 transition-colors"
                  >
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                    </svg>
                    <span class="font-medium text-gray-700">Website</span>
                  </a>
                )}
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="lg:w-2/3 space-y-16">
            <!-- Bio -->
            <div class="animate-fade-in stagger-2" style="opacity: 0;">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">Biography</h2>
              <div class="prose prose-lg text-gray-600">
                <p class="mb-4">
                  {user?.bio || 'AI researcher and engineer passionate about machine learning, deep learning, and natural language processing. Building intelligent systems that solve real-world problems.'}
                </p>
                <p>
                  With years of experience in developing and deploying machine learning models at scale, I focus on creating systems that are not only technically excellent but also practical and accessible. My work spans from research-oriented projects exploring cutting-edge AI capabilities to production systems serving millions of users.
                </p>
              </div>
            </div>

            <!-- Experience -->
            <div class="animate-fade-in stagger-3" style="opacity: 0;">
              <h2 class="text-2xl font-bold text-gray-900 mb-6">Experience</h2>
              <div class="space-y-6">
                {experiences.map((exp, index) => (
                  <div class="relative pl-8 border-l-2 border-indigo-200">
                    <div class="absolute -left-2 top-0 w-4 h-4 bg-indigo-500 rounded-full ring-4 ring-white"></div>
                    <div class="bg-gray-50 rounded-xl p-5">
                      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
                        <h3 class="text-lg font-bold text-gray-900">{exp.title}</h3>
                        <span class="text-sm text-indigo-600 font-medium">{exp.period}</span>
                      </div>
                      <p class="text-indigo-600 font-medium mb-2">{exp.company}</p>
                      <p class="text-gray-600">{exp.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Education -->
            <div class="animate-fade-in stagger-4" style="opacity: 0;">
              <h2 class="text-2xl font-bold text-gray-900 mb-6">Education</h2>
              <div class="space-y-4">
                {education.map((edu) => (
                  <div class="bg-gray-50 rounded-xl p-5">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
                      <h3 class="text-lg font-bold text-gray-900">{edu.degree}</h3>
                      <span class="text-sm text-indigo-600 font-medium">{edu.year}</span>
                    </div>
                    <p class="text-indigo-600 font-medium mb-1">{edu.school}</p>
                    <p class="text-sm text-gray-500">{edu.focus}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Interests -->
            <div class="animate-fade-in stagger-5" style="opacity: 0;">
              <h2 class="text-2xl font-bold text-gray-900 mb-6">Interests & Focus Areas</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                {[
                  { emoji: '🤖', title: 'Large Language Models', desc: 'GPT, BERT, and beyond' },
                  { emoji: '🖼️', title: 'Computer Vision', desc: 'Image recognition & generation' },
                  { emoji: '📊', title: 'MLOps', desc: 'ML system design & deployment' },
                  { emoji: '🎯', title: 'Reinforcement Learning', desc: 'Agent-based learning' },
                  { emoji: '🔧', title: 'ML Frameworks', desc: 'PyTorch, TensorFlow, JAX' },
                  { emoji: '☁️', title: 'Cloud Computing', desc: 'AWS, GCP, Azure' },
                ].map((item) => (
                  <div class="p-4 bg-gray-50 rounded-xl text-center hover:bg-indigo-50 transition-colors">
                    <div class="text-3xl mb-2">{item.emoji}</div>
                    <h3 class="font-semibold text-gray-900 text-sm">{item.title}</h3>
                    <p class="text-xs text-gray-500">{item.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
